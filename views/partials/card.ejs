<a href="/<%= data.type %>/<%= data.slug %>" class="card">
    <div class="card-icon"><%= data.emoji %></div>
    <div class="card-body">
        <h3><%= data.name %></h3>
        <p><%= data.description %></p>
        <span class="card-meta"><%= data.count %> <%= data.metaType %></span>
    </div>
    <span class="card-arrow">→</span>
</a>