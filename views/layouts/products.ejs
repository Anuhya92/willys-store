<%- include('../partials/head', { title: 'Products' }) %>
<%- include('../partials/nav', { activePage: 'products' }) %>

<main>
  <section class="page-hero page-hero--products">
    <div class="page-hero-content">
      <h1>Our Products</h1>
      <p>Discover fresh quality across all our categories</p>
    </div>
  </section>

  <section class="page-content">
    <div class="container">
      <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
        <div class="cards-grid">
          <% categories.forEach(function(cat) { %>
            <%- include('../partials/card', { data: { ...cat, type: 'products', metaType: 'items' } }) %>
          <% }) %>
        </div>
      <% } else { %>
        <p class="empty-msg">No product categories found.</p>
      <% } %>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
